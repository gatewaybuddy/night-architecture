# Night Architecture Docker Environment
# This file configures the Docker-based Night Architecture system

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_FALLBACK_MODEL=deepseek-coder-v2:16b

# Shared Volume Path (mounted in containers)
SHARED_PATH=/workspace/shared

# Redis Configuration (for future agent coordination)
REDIS_URL=redis://localhost:6380/0

# PostgreSQL Configuration (for pattern storage)
DATABASE_URL=postgresql://nightarch:nightarch_dev_password@localhost:5433/nightarch

# Claude Code Configuration
CLAUDE_MAX_HOURS_PER_WEEK=280
CLAUDE_MODE=autonomous

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true
